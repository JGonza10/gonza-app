# Copia este archivo como .env y llena tus valores reales
# NUNCA subas .env a GitHub

# Conexión a PostgreSQL (Railway la inyecta automáticamente en producción)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/gonza_db

# Puerto del servidor Flask
PORT=5000

# API Key de Resend para envío de correos
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# URL del frontend React (para CORS en producción)
FRONTEND_URL=https://gonza-frontend.up.railway.app

# ─── PROTECCIÓN CRON JOB ─────────────────────────────────────────────────────
# Secret compartido entre Railway Cron y el backend.
# Genera uno seguro con:  python3 -c "import secrets; print(secrets.token_hex(32))"
# El cron job debe enviarlo como header:  X-Cron-Secret: <valor>
CRON_SECRET=pon_aqui_un_token_largo_y_aleatorio
